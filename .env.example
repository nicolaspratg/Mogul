# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/alpchat

# ─── Meta / WhatsApp ──────────────────────────────────────────────────────────
# HMAC secret from the Meta App Dashboard (App > Webhooks > App Secret)
META_APP_SECRET=your_meta_app_secret_here

# Token you set when registering the webhook with Meta (Webhooks > Verify Token)
META_WEBHOOK_VERIFY_TOKEN=your_verify_token_here

# ─── Optional tunables ────────────────────────────────────────────────────────
# Conversation idle TTL in hours (default: 24)
# CONVERSATION_TTL_HOURS=24

# How often the in-process cleanup job runs, in milliseconds (default: 900000 = 15 min)
# CLEANUP_INTERVAL_MS=900000
